# Default all text files to LF for consistent cross-platform diffs
* text=auto eol=lf

# Source and scripts
*.py text eol=lf
*.pyi text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Web and templates
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Docs and config
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
docker/**/*.yml text eol=lf

# Dependency and lock files
requirements*.txt text eol=lf
Pipfile.lock text eol=lf
poetry.lock text eol=lf

# Compiled and binary assets
*.pyc binary
*.pyo binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.exe binary
*.dll binary
*.so binary

# Reduce merge conflicts in dependency lists
requirements*.txt merge=union
