> def _apply_event_effects(
>     hero: Hero | None,
>     effect_defs: list,
>     rng: DeterministicRng,
>     party: Party | None = None,
> ) -> dict:
>     target_party = party or (hero.party if hero else None)
>     applied = {"hero_health_delta": 0, "party_gold_delta": 0, "party_morale_delta": 0}
  
>     for effect in effect_defs:
>         effect_type = effect.get("type")
>         min_value = int(effect.get("min", 0))
>         max_value = int(effect.get("max", min_value))
>         value = rng.randint(min_value, max_value) if max_value >= min_value else min_value
  
>         if effect_type == "hero_health" and hero:
>             hero.current_health = max(0, min(hero.max_health, hero.current_health + value))
>             applied["hero_health_delta"] += value
>         elif effect_type == "party_gold" and target_party:
>             target_party.gold = max(0, target_party.gold + value)
>             applied["party_gold_delta"] += value
>         elif effect_type == "party_morale" and target_party:
>             target_party.morale += value
>             applied["party_morale_delta"] += value
  
>     if hero:
>         hero.save(update_fields=["current_health", "updated_at"])
>     if target_party:
>         target_party.save(update_fields=["gold", "morale", "updated_at"])
>     return applied
  
  
> def _next_seed(campaign, step_type: str, action_type: str, actor_key: str) -> str:
>     sequence = campaign.step_logs.count() + 1
>     return derive_step_seed(campaign.seed, step_type, action_type, actor_key, sequence)
  
  
> def _apply_settlement_rule_flag(hero: Hero, rule_flag: str | None) -> None:
>     if not rule_flag:
>         return
  
>     party = hero.party
>     if rule_flag == "future_income":
>         hero.investment_active = True
>     elif rule_flag in {"forced_departure_or_delay", "may_force_departure"}:
>         party.forced_departure = True
>     elif rule_flag == "service_delay":
>         hero.days_unavailable += 7
>     elif rule_flag == "bed_rest":
>         hero.days_unavailable += 2
>     elif rule_flag == "pet_dog":
>         hero.has_pet_dog = True
>     elif rule_flag == "jail":
>         hero.days_unavailable += 1
>     elif rule_flag == "reroll_attack_once":
>         hero.temple_reroll_charges += 1
>     elif rule_flag == "possible_disguise_or_exile":
>         hero.in_disguise = True
>     elif rule_flag == "recovery_delay":
>         hero.days_unavailable += 1
  
>     hero.save(
>         update_fields=[
>             "investment_active",
>             "days_unavailable",
>             "has_pet_dog",
>             "temple_reroll_charges",
>             "in_disguise",
>             "updated_at",
>         ]
>     )
>     party.save(update_fields=["forced_departure", "updated_at"])
  
  
